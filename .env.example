# 브라우저에 공개 가능한 값만 NEXT_PUBLIC_ 접두사를 사용합니다.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 외부 연동 도입 시 서버 전용으로 사용합니다.
KAKAO_REST_API_KEY=
DATA_GO_KR_SERVICE_KEY=
# 새 프로젝트는 Secret key 사용을 우선합니다.
SUPABASE_SECRET_KEY=
# 레거시 프로젝트 호환용이며 브라우저에서 사용하면 안 됩니다.
SUPABASE_SERVICE_ROLE_KEY=
ENABLE_DEMO_ADMIN=false

# Supabase 도입 시 공개 범위를 확인한 뒤 사용합니다.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
