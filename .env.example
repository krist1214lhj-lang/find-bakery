# 브라우저에 공개 가능한 값만 NEXT_PUBLIC_ 접두사를 사용합니다.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 외부 연동 도입 시 서버 전용으로 사용합니다.
KAKAO_REST_API_KEY=
DATA_GO_KR_SERVICE_KEY=
# 공공데이터포털 상세 명세의 반경 조회 URL이 변경될 때만 재정의합니다.
DATA_GO_KR_STORE_API_URL=
# 새 프로젝트는 Secret key 사용을 우선합니다.
SUPABASE_SECRET_KEY=
# 레거시 프로젝트 호환용이며 브라우저에서 사용하면 안 됩니다.
SUPABASE_SERVICE_ROLE_KEY=
ENABLE_DEMO_ADMIN=false

# 브라우저와 서버의 공개 조회 클라이언트가 RLS를 통해 사용합니다.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
